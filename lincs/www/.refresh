#!/bin/sh

#
# $Id: .refresh,v 1.3 2004/03/01 14:49:20 amelinte Exp $ 
# Update web site with documents from tiger/ and lincs/ distributions.  
#

cp -u ../src/lincs/doc/site/*           lincs/site/
cp -u ../src/lincs/doc/architecture/*   lincs/architecture/
cp -u ../src/tiger/doc/site/*           tiger/site/
cp -u ../src/tiger/doc/architecture/*   tiger/architecture/

echo "Done!"

